{
  "name": "pokemon-champions",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "check": "turbo run lint typecheck test build",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "infra:up": "docker compose -f infrastructure/docker/docker-compose.yml up -d --wait",
    "infra:down": "docker compose -f infrastructure/docker/docker-compose.yml down",
    "db:generate": "pnpm --filter @pokemon-champions/database db:generate",
    "db:migrate": "pnpm --filter @pokemon-champions/database db:migrate",
    "db:check": "pnpm --filter @pokemon-champions/database db:check"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "eslint": "^9.20.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "globals": "^15.14.0",
    "prettier": "^3.5.0",
    "turbo": "^2.5.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.24.0"
  }
}
