# ============================================================
# ルート .env — Docker Compose(ローカルインフラ)用
# 使い方: cp .env.example .env
# 秘密情報は .env にのみ書き、Git にコミットしないこと
# ============================================================

# PostgreSQL コンテナ設定
POSTGRES_USER=pokemon
POSTGRES_PASSWORD=pokemon_local_dev
POSTGRES_DB=pokemon_champions
POSTGRES_PORT=5432

# Redis コンテナ設定
REDIS_PORT=6379
