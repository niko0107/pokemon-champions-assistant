# ============================================================
# apps/api — バックエンド環境変数
# 使い方: cp .env.example .env
# 秘密情報は .env にのみ書き、Git にコミットしないこと
# ============================================================

# サーバー
PORT=3000
# CORS 許可オリジン(カンマ区切り)
CORS_ORIGIN=http://localhost:5173

# PostgreSQL(ルート .env の POSTGRES_* と一致させる)
DATABASE_URL="postgresql://pokemon:pokemon_local_dev@localhost:5432/pokemon_champions?schema=public"

# Redis(SETUP-010 以降で使用)
REDIS_URL="redis://localhost:6379"

# JWTアクセストークン(AUTH-002。openssl rand -base64 32 等で生成すること)
JWT_ACCESS_SECRET=changeme-generate-a-real-secret
JWT_ACCESS_EXPIRES_IN=15m

# opaqueリフレッシュトークンのHMAC鍵(AUTH-003。アクセストークン鍵とは別に生成すること)
JWT_REFRESH_SECRET=changeme-generate-a-real-secret
JWT_REFRESH_EXPIRES_IN=30d

# Anthropic API(LLM-001 以降で使用。未設定でもサービスは動作すること)
# ANTHROPIC_API_KEY=
