{
  "name": "@pokemon-champions/database",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "prisma generate && tsup",
    "lint": "eslint src scripts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:check": "tsx scripts/check-connection.ts",
    "db:seed": "pnpm --filter @pokemon-champions/shared build && tsx scripts/seed-sample.ts"
  },
  "dependencies": {
    "@pokemon-champions/shared": "workspace:*",
    "@prisma/client": "^6.4.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "prisma": "^6.4.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  }
}
