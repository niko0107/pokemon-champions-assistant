// Pokémon Champions 対戦支援サービス — Prisma スキーマ
//
// 設計書 docs/PRODUCT_SPEC.md §6 の全テーブルは、以下のタスクで段階的に追加する:
//   MASTER-001〜004(マスタ系)/ AUTH-001, PARTY-001(ユーザー系)
//   ARCHETYPE-001〜003(テンプレ構築系)/ BATTLE-001〜002(セッション系)
// マイグレーション運用は docs/DATABASE_MIGRATION_POLICY.md を参照。

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// 接続確認・マイグレーション基盤確認用の最小モデル。
/// 本格スキーマ導入後も、死活監視の書き込み確認先として利用できる。
model SystemHealthCheck {
  id        Int      @id @default(autoincrement())
  note      String?
  checkedAt DateTime @default(now()) @map("checked_at")

  @@map("system_health_checks")
}

/// 認証・認可の主体となるユーザー。passwordHashはOAuth専用ユーザーではnull。
model User {
  id            String         @id @default(uuid()) @db.Uuid
  email         String         @unique @db.VarChar(254)
  passwordHash  String?        @map("password_hash") @db.VarChar(255)
  displayName   String         @map("display_name") @db.VarChar(50)
  role          String         @default("user")
  createdAt     DateTime       @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt     DateTime       @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(3)
  refreshTokens RefreshToken[]

  @@map("users")
}

/// ローテーションと再利用検出に使用するリフレッシュトークンの永続状態。
/// tokenHashにはopaque token本体ではなくHMAC-SHA-256のhex digestだけを保存する。
model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash") @db.Char(64)
  familyId  String    @map("family_id") @db.Uuid
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(3)
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz(3)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([userId, revokedAt])
  @@index([familyId, revokedAt])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

/// ポケモンマスタ。通常形態・派生形態を1行ずつ保持する。
model Pokemon {
  id               Int                @id @default(autoincrement())
  dexNo            Int                @map("dex_no")
  nameJa           String             @map("name_ja")
  nameEn           String             @map("name_en")
  form             String
  type1            String
  type2            String?
  baseHp           Int                @map("base_hp")
  baseAtk          Int                @map("base_atk")
  baseDef          Int                @map("base_def")
  baseSpa          Int                @map("base_spa")
  baseSpd          Int                @map("base_spd")
  baseSpe          Int                @map("base_spe")
  abilities        Json               @db.JsonB
  isMega           Boolean            @default(false) @map("is_mega")
  basePokemonId    Int?               @map("base_pokemon_id")
  basePokemon      Pokemon?           @relation("PokemonForms", fields: [basePokemonId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  derivedForms     Pokemon[]          @relation("PokemonForms")
  learnableMoves   PokemonMove[]
  archetypeEntries ArchetypePokemon[]

  @@unique([dexNo, form])
  @@index([nameJa])
  @@index([nameEn])
  @@index([basePokemonId])
  @@map("pokemons")
}

/// 技マスタ。分類・数値性能と警戒判定用タグを保持する。
model Move {
  id               Int                    @id @default(autoincrement())
  nameJa           String                 @unique @map("name_ja")
  nameEn           String                 @unique @map("name_en")
  type             String
  category         String
  power            Int?
  accuracy         Int?
  priority         Int                    @default(0)
  tags             Json                   @db.JsonB
  learnedBy        PokemonMove[]
  archetypeEntries ArchetypePokemonMove[]

  @@index([tags], type: Gin)
  @@map("moves")
}

/// 持ち物マスタ。相性・一致判定用の効果分類タグを保持する。
model Item {
  id               Int                @id @default(autoincrement())
  nameJa           String             @unique @map("name_ja")
  nameEn           String             @unique @map("name_en")
  effectTags       Json               @map("effect_tags") @db.JsonB
  archetypeEntries ArchetypePokemon[]

  @@index([effectTags], type: Gin)
  @@map("items")
}

/// 特性マスタ。相性判定用の効果分類タグを保持する。
model Ability {
  id               Int                @id @default(autoincrement())
  nameJa           String             @unique @map("name_ja")
  nameEn           String             @unique @map("name_en")
  effectTags       Json               @map("effect_tags") @db.JsonB
  archetypeEntries ArchetypePokemon[]

  @@index([effectTags], type: Gin)
  @@map("abilities")
}

/// フォルム単位のポケモンと習得可能技を結ぶ中間モデル。
model PokemonMove {
  pokemonId Int     @map("pokemon_id")
  moveId    Int     @map("move_id")
  pokemon   Pokemon @relation(fields: [pokemonId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  move      Move    @relation(fields: [moveId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@id([pokemonId, moveId])
  @@index([moveId])
  @@map("pokemon_moves")
}

/// 対象期間を持つシーズンマスタ。
model Season {
  id         Int         @id @default(autoincrement())
  name       String      @unique
  startsAt   DateTime    @map("starts_at") @db.Date
  endsAt     DateTime    @map("ends_at") @db.Date
  archetypes Archetype[]

  @@index([startsAt, endsAt])
  @@map("seasons")
}

/// 対戦時のチーム人数・選出人数を持つルールマスタ。
model Rule {
  id         Int         @id @default(autoincrement())
  name       String      @unique
  teamSize   Int         @map("team_size")
  pickSize   Int         @map("pick_size")
  archetypes Archetype[]

  @@map("rules")
}

/// シーズン・ルール単位のテンプレ構築本体。
model Archetype {
  id              String             @id @default(uuid()) @db.Uuid
  name            String             @db.VarChar(100)
  description     String
  seasonId        Int                @map("season_id")
  ruleId          Int                @map("rule_id")
  popularityTier  String             @default("mid") @map("popularity_tier")
  popularityScore Decimal?           @map("popularity_score") @db.Decimal(7, 4)
  encounterCount  Int                @default(0) @map("encounter_count")
  pickCount       Int                @default(0) @map("pick_count")
  defaultLeads    Json               @map("default_leads") @db.JsonB
  playstyleNotes  String             @map("playstyle_notes")
  status          String             @default("published")
  publishedAt     DateTime           @default(now()) @map("published_at") @db.Timestamptz(3)
  createdAt       DateTime           @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt       DateTime           @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(3)
  season          Season             @relation(fields: [seasonId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  rule            Rule               @relation(fields: [ruleId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  pokemons        ArchetypePokemon[]
  sources         ArchetypeSource[]

  @@index([seasonId, ruleId, status])
  @@index([popularityTier, encounterCount, updatedAt])
  @@map("archetypes")
}

/// テンプレ構築内の採用ポケモン。slotが構築内の決定的な並び順を表す。
model ArchetypePokemon {
  id               String                 @id @default(uuid()) @db.Uuid
  archetypeId      String                 @map("archetype_id") @db.Uuid
  slot             Int
  pokemonId        Int                    @map("pokemon_id")
  itemId           Int?                   @map("item_id")
  itemAlternatives Json                   @map("item_alternatives") @db.JsonB
  abilityId        Int?                   @map("ability_id")
  nature           String?
  teraType         String?                @map("tera_type")
  evs              Json?                  @db.JsonB
  role             String
  usageRate        Decimal                @default(1.0) @map("usage_rate") @db.Decimal(5, 4)
  threatNotes      String?                @map("threat_notes")
  archetype        Archetype              @relation(fields: [archetypeId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  pokemon          Pokemon                @relation(fields: [pokemonId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  item             Item?                  @relation(fields: [itemId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  ability          Ability?               @relation(fields: [abilityId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  moves            ArchetypePokemonMove[]

  @@unique([archetypeId, slot])
  @@unique([archetypeId, pokemonId])
  @@index([pokemonId])
  @@index([itemId])
  @@index([abilityId])
  @@map("archetype_pokemons")
}

/// テンプレ構築内ポケモンの採用技と採用率。
model ArchetypePokemonMove {
  archetypePokemonId String           @map("archetype_pokemon_id") @db.Uuid
  moveId             Int              @map("move_id")
  adoptionRate       Decimal          @default(1.0) @map("adoption_rate") @db.Decimal(5, 4)
  archetypePokemon   ArchetypePokemon @relation(fields: [archetypePokemonId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  move               Move             @relation(fields: [moveId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@id([archetypePokemonId, moveId])
  @@index([moveId])
  @@map("archetype_pokemon_moves")
}

/// 構築データの根拠となる外部記事。本文・画像は保存せず出典情報だけを保持する。
model ArchetypeSource {
  id          String    @id @default(uuid()) @db.Uuid
  archetypeId String    @map("archetype_id") @db.Uuid
  title       String
  url         String    @db.VarChar(2048)
  siteName    String    @map("site_name")
  siteRank    Int?      @map("site_rank")
  archetype   Archetype @relation(fields: [archetypeId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([archetypeId, url])
  @@map("archetype_sources")
}
