// Pokémon Champions 対戦支援サービス — Prisma スキーマ
//
// 設計書 docs/PRODUCT_SPEC.md §6 の全テーブルは、以下のタスクで段階的に追加する:
//   MASTER-001〜004(マスタ系)/ USER-001, PARTY-001(ユーザー系)
//   ARCHETYPE-001〜003(テンプレ構築系)/ BATTLE-001〜002(セッション系)
// マイグレーション運用は docs/DATABASE_MIGRATION_POLICY.md を参照。

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// 接続確認・マイグレーション基盤確認用の最小モデル。
/// 本格スキーマ導入後も、死活監視の書き込み確認先として利用できる。
model SystemHealthCheck {
  id        Int      @id @default(autoincrement())
  note      String?
  checkedAt DateTime @default(now()) @map("checked_at")

  @@map("system_health_checks")
}

/// ポケモンマスタ。通常形態・派生形態を1行ずつ保持する。
model Pokemon {
  id            Int       @id @default(autoincrement())
  dexNo         Int       @map("dex_no")
  nameJa        String    @map("name_ja")
  nameEn        String    @map("name_en")
  form          String
  type1         String
  type2         String?
  baseHp        Int       @map("base_hp")
  baseAtk       Int       @map("base_atk")
  baseDef       Int       @map("base_def")
  baseSpa       Int       @map("base_spa")
  baseSpd       Int       @map("base_spd")
  baseSpe       Int       @map("base_spe")
  abilities     Json      @db.JsonB
  isMega        Boolean   @default(false) @map("is_mega")
  basePokemonId Int?      @map("base_pokemon_id")
  basePokemon   Pokemon?  @relation("PokemonForms", fields: [basePokemonId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  derivedForms  Pokemon[] @relation("PokemonForms")

  @@unique([dexNo, form])
  @@index([nameJa])
  @@index([nameEn])
  @@index([basePokemonId])
  @@map("pokemons")
}

/// 技マスタ。分類・数値性能と警戒判定用タグを保持する。
model Move {
  id       Int    @id @default(autoincrement())
  nameJa   String @unique @map("name_ja")
  nameEn   String @unique @map("name_en")
  type     String
  category String
  power    Int?
  accuracy Int?
  priority Int    @default(0)
  tags     Json   @db.JsonB

  @@index([tags], type: Gin)
  @@map("moves")
}

/// 持ち物マスタ。相性・一致判定用の効果分類タグを保持する。
model Item {
  id         Int    @id @default(autoincrement())
  nameJa     String @unique @map("name_ja")
  nameEn     String @unique @map("name_en")
  effectTags Json   @map("effect_tags") @db.JsonB

  @@index([effectTags], type: Gin)
  @@map("items")
}

/// 特性マスタ。相性判定用の効果分類タグを保持する。
model Ability {
  id         Int    @id @default(autoincrement())
  nameJa     String @unique @map("name_ja")
  nameEn     String @unique @map("name_en")
  effectTags Json   @map("effect_tags") @db.JsonB

  @@index([effectTags], type: Gin)
  @@map("abilities")
}
